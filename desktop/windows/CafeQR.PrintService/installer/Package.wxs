<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package Name="CafeQR Print Service"
           Manufacturer="CafeQR"
           Version="$(ServiceVersion)"
           UpgradeCode="A02B64A9-1437-43D8-9B13-4C0C79E57A51"
           Scope="perMachine"
           InstallerVersion="500">
    <MajorUpgrade DowngradeErrorMessage="A newer CafeQR Print Service is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="CafeQRFolder" Name="CafeQR">
        <Directory Id="INSTALLFOLDER" Name="Print Service" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="CafeQR" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="CafeQR Print Service" Level="1">
      <ComponentGroupRef Id="ServiceFiles" />
      <ComponentRef Id="ServiceRegistration" />
      <ComponentRef Id="TrayStartup" />
      <ComponentRef Id="ProgramMenuShortcut" />
    </Feature>

    <ComponentGroup Id="ServiceFiles" Directory="INSTALLFOLDER">
      <Files Include="$(PublishDir)\**">
        <Exclude Files="$(PublishDir)\CafeQR.PrintService.exe" />
      </Files>
    </ComponentGroup>

    <Component Id="ServiceRegistration" Directory="INSTALLFOLDER" Guid="B395563A-744F-4468-A114-F26621639DC0">
      <File Id="ServiceExecutable" Source="$(PublishDir)\CafeQR.PrintService.exe" KeyPath="yes" />
      <ServiceInstall Id="PrintServiceInstall"
                      Name="CafeQRPrintService"
                      DisplayName="CafeQR Print Service"
                      Description="Durable local printing for CafeQR POS"
                      Type="ownProcess"
                      Start="auto"
                      ErrorControl="normal"
                      Account="LocalSystem"
                      Vital="yes">
        <util:ServiceConfig FirstFailureActionType="restart"
                            SecondFailureActionType="restart"
                            ThirdFailureActionType="restart"
                            RestartServiceDelayInSeconds="5"
                            ResetPeriodInDays="1" />
      </ServiceInstall>
      <ServiceControl Id="PrintServiceControl"
                      Name="CafeQRPrintService"
                      Start="install"
                      Stop="both"
                      Remove="uninstall"
                      Wait="yes" />
    </Component>

    <Component Id="TrayStartup" Directory="INSTALLFOLDER" Guid="50E4AE14-91C2-4869-8146-7A0D76A483EF">
      <RegistryValue Root="HKLM"
                     Key="Software\Microsoft\Windows\CurrentVersion\Run"
                     Name="CafeQRPrintTray"
                     Value="&quot;[INSTALLFOLDER]CafeQR.PrintTray.exe&quot;"
                     Type="string"
                     KeyPath="yes" />
    </Component>

    <Component Id="ProgramMenuShortcut" Directory="ApplicationProgramsFolder" Guid="C2DBAC38-A90C-412B-8A14-63B9BCAB79AC">
      <Shortcut Id="PrintDiagnosticsShortcut"
                Name="CafeQR Print Diagnostics"
                Target="[INSTALLFOLDER]CafeQR.PrintTray.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\CafeQR\PrintService" Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Package>
</Wix>
